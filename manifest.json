{
  "manifest_version": 3,
  "name": "YouTube Channel Video URL Extractor",
  "description": "Collects video links from a YouTube channel videos page from oldest to newest.",
  "version": "1.1.0",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Extract YouTube URLs"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
